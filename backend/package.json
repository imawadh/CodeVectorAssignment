    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
